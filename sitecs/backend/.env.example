# ─────────────────────────────────────────────────────────────
#  SITECS Backend — Environment Variables
#  Copy this file to .env and fill in your real values.
#  NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────────

# Server
PORT=5000
NODE_ENV=development

# CORS — comma-separated list of allowed origins
# Development:  http://localhost:5173
# Production:   https://sitecs.vercel.app,https://www.sitecs.com
ALLOWED_ORIGINS=http://localhost:5173

# ── Firebase Admin SDK ────────────────────────────────────────
# Option A (recommended): path to your service-account JSON file
#   Download from Firebase Console → Project Settings → Service Accounts
FIREBASE_SERVICE_ACCOUNT_PATH=./serviceAccountKey.json

# Option B: inline credentials (useful for deployment platforms)
# Uncomment and fill these if you don't use the JSON file.
# FIREBASE_PROJECT_ID=your-project-id
# FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project-id.iam.gserviceaccount.com
# FIREBASE_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\nYOUR_KEY\n-----END RSA PRIVATE KEY-----\n"
