# ─────────────────────────────────────────────────────────────
#  SITECS Frontend — Vite Environment Variables
#  Copy this file to .env.local and fill in your values.
#  Vite exposes only variables prefixed with VITE_ to the browser.
# ─────────────────────────────────────────────────────────────

# Points the Contact form to your Express backend.
# Development (default if this var is missing): http://localhost:5000
VITE_API_URL=http://localhost:5000

# Production example:
# VITE_API_URL=https://api.sitecs.com
